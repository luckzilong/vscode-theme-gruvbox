{
	"name": "gruvbox",
	"version": "0.0.0",
	"author": "luzilong",
	"repository": {
		"type": "github",
		"url": "https://github.com/luckzilong/vscode-theme-gruvbox.git"
	},
	"devDependencies": {
		"@eslint/js": "^9.21.0",
		"@types/node": "^22.13.7",
		"@types/tinycolor2": "^1.4.6",
		"@vscode/vsce": "^3.2.2",
		"es-toolkit": "^1.37.2",
		"eslint": "^9.21.0",
		"eslint-config-prettier": "^10.0.2",
		"ovsx": "^0.10.1",
		"prettier": "3.5.2",
		"semantic-release": "^24.2.3",
		"tinycolor2": "^1.6.0",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.25.0",
		"vsce": "^2.15.0"
	},
	"categories": [
		"Themes"
	],
	"contributes": {
		"themes": [
			{
				"label": "Gruvbox Dark Medium",
				"uiTheme": "vs-dark",
				"path": "./themes/gruvbox-dark-medium.json"
			},
			{
				"label": "Gruvbox Dark Hard",
				"uiTheme": "vs-dark",
				"path": "./themes/gruvbox-dark-hard.json"
			},
			{
				"label": "Gruvbox Dark Soft",
				"uiTheme": "vs-dark",
				"path": "./themes/gruvbox-dark-soft.json"
			},
			{
				"label": "Gruvbox Light Medium",
				"uiTheme": "vs",
				"path": "./themes/gruvbox-light-medium.json"
			},
			{
				"label": "Gruvbox Light Hard",
				"uiTheme": "vs",
				"path": "./themes/gruvbox-light-hard.json"
			},
			{
				"label": "Gruvbox Light Soft",
				"uiTheme": "vs",
				"path": "./themes/gruvbox-light-soft.json"
			}
		]
	},
	"description": "Gruvbox Theme. source author jdinhify (https://github.com/jdinhify), repository https://github.com/jdinhify/vscode-theme-gruvbox.git",
	"displayName": "Gruvbox Theme",
	"engines": {
		"vscode": "^1.67.2"
	},
	"galleryBanner": {
		"color": "#3c3836",
		"theme": "dark"
	},
	"homepage": "https://github.com/luckzilong/vscode-theme-gruvbox",
	"icon": "images/icon.png",
	"license": "MIT",
	"private": true,
	"publisher": "luzilong",
	"scripts": {
		"semantic-release": "semantic-release",
		"dev": "tsx watch ./src/main.ts",
		"build": "tsx ./src/main.ts",
		"type:check": "tsc ./src/*.ts --noEmit",
		"lint:check": "eslint ./src",
		"format:check": "prettier ./src --check"
	},
	"type": "module"
}
