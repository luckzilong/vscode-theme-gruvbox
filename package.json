{
	"name": "gruvbox",
	"displayName": "Gruvbox Theme",
	"description": "Gruvbox Theme, Source author: jdinhify (https://github.com/jdinhify)",
	"version": "0.0.0",
	"author": "luzilong",
	"publisher": "luzilong",
	"engines": {
		"vscode": "^1.67.2"
	},
	"categories": [
		"Themes"
	],
	"icon": "images/icon.png",
	"galleryBanner": {
		"color": "#3c3836",
		"theme": "dark"
	},
	"homepage": "https://github.com/jdinhify/vscode-theme-gruvbox",
	"repository": {
		"type": "git",
		"url": "https://github.com/jdinhify/vscode-theme-gruvbox.git"
	},
	"contributes": {
		"themes": [
			{
				"label": "Gruvbox Dark",
				"uiTheme": "vs-dark",
				"path": "./themes/gruvbox-dark.json"
			}
		]
	},
	"devDependencies": {
		"@eslint/js": "^9.21.0",
		"@types/node": "^22.13.7",
		"@vscode/vsce": "^3.2.2",
		"eslint": "^9.21.0",
		"eslint-config-prettier": "^10.0.2",
		"ovsx": "^0.10.1",
		"prettier": "3.5.2",
		"semantic-release": "^24.2.3",
		"tsx": "^4.19.3",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.25.0",
		"vsce": "^2.15.0"
	},
	"private": true,
	"scripts": {
		"semantic-release": "semantic-release",
		"dev": "tsx watch ./src/main.ts",
		"build": "tsx ./src/main.ts",
		"type:check": "tsc ./src/*.ts --noEmit",
		"lint:check": "eslint ./src",
		"format:check": "prettier ./src --check",
    "build:local":"vsce package"
	},
	"license": "MIT",
	"type": "module",
	"dependencies": {
		"es-toolkit": "^1.39.5"
	}
}
